        "exec": [
          "// Generate unique emails once per run so re-runs don't hit 409\r",
          "if (!pm.collectionVariables.get('ownerEmail')) {\r",
          "  const stamp = Date.now();\r",
          "  pm.collectionVariables.set('ownerEmail', 'owner_' + stamp + '@test.com');\r",
          "  pm.collectionVariables.set('viewerEmail', 'viewer_' + stamp + '@test.com');\r",
          "  pm.collectionVariables.set('password', 'Password123');\r",
          "}"
