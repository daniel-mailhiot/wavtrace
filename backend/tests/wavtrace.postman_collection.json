              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 created', () => pm.response.to.have.status(201));\r",
                  "const body = pm.response.json();\r",
                  "pm.collectionVariables.set('ownerId', body.id);\r",
                  "pm.test('returns email', () =>\r",
                  "  pm.expect(body.email).to.eql(pm.collectionVariables.get('ownerEmail')));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{ \r\n    \"name\": \"Owner\", \r\n    \"email\": \"{{ownerEmail}}\", \r\n    \"password\": \"{{password}}\"\r\n}",
              "options": {
